# ===== Nissan AI Market Intelligence - 環境変数 =====

# 銘柄(既定: 日産自動車 7201.T)
NEXT_PUBLIC_TICKER=7201.T

# NewsAPI (https://newsapi.org/ で無料キー取得)
# 未設定でもアプリは動作します(モックニュースにフォールバック)
NEWS_API_KEY=

# モデル予測API(FastAPI/LightGBM)のURL。未設定なら内蔵のstatic予測を返す
PREDICTION_API_URL=

# ===== 生成AI解説 (Groq Cloud, OpenAI互換) =====
# https://console.groq.com/keys で無料キー取得。未設定でもルールベース解説で動作。
GROQ_API_KEY=
# 任意: モデルとエンドポイント(既定はGroqのLlama 3.3 70B)
# xAI Grok を使う場合は GROQ_BASE_URL=https://api.x.ai/v1, GROQ_MODEL=grok-2-latest
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ===== スマホ通知 (ntfy.sh) =====
# ntfyアプリで購読する「推測されにくいトピック名」を設定(例: nissan-ai-x7k2q)
NTFY_TOPIC=
# 任意: セルフホストntfyを使う場合のサーバURL(既定 https://ntfy.sh)
NTFY_SERVER=https://ntfy.sh
# 任意: 認証付きトピックの場合のトークン
NTFY_TOKEN=
# Cronエンドポイント保護用シークレット(Vercel Cronが自動でBearer付与)
CRON_SECRET=
# 通知のクリック先(本番URL)
NEXT_PUBLIC_SITE_URL=https://nissan-ai-market-intelligence.vercel.app
